# Fundflow backend API base URL (no trailing slash). All requests are sent to <URL>/api/v1/*
NEXT_PUBLIC_API_URL=http://localhost:8000

# NextAuth (Auth.js) session-cookie encryption secret.
# Generate one with:  npx auth secret    (or:  openssl rand -base64 33)
AUTH_SECRET=

# Google OAuth 2.0 "Web application" client credentials.
# Google Cloud Console -> APIs & Services -> Credentials -> Create OAuth client ID.
#   Authorized JavaScript origin:  http://localhost:3000
#   Authorized redirect URI:       http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
